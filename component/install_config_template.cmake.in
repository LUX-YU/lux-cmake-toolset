@PACKAGE_INIT@

# set(components_list @EXPORT_NAME_LIST@)
set(PROJECT_NAME @INSTALL_ARGS_PROJECT_NAME@)

foreach(component ${${PROJECT_NAME}_FIND_COMPONENTS})
  set(CONFIG_FILE_NAME ${PROJECT_NAME}-${component}-config-targets.cmake)
  include(${CMAKE_CURRENT_LIST_DIR}/${CONFIG_FILE_NAME})
endforeach()
